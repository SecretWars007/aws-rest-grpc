{
  "name": "yape-monorepo",
  "version": "1.0.0",
  "description": "Yape BCP REST & gRPC microservices with Clean Architecture",
  "private": true,
  "workspaces": [
    "m1-rest",
    "m2-grpc"
  ],
  "scripts": {
    "build:m1": "npm run build --workspace=m1-rest",
    "build:m2": "npm run build --workspace=m2-grpc",
    "start:m1": "npm run start --workspace=m1-rest",
    "start:m2": "npm run start --workspace=m2-grpc",
    "dev:m1": "npm run dev --workspace=m1-rest",
    "dev:m2": "npm run dev --workspace=m2-grpc"
  }
}
